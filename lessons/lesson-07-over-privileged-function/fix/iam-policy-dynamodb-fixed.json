{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SendReceiptDynamoDBScoped",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:<ACCOUNT-ID>:table/DVSA-ORDERS-DB",
        "arn:aws:dynamodb:us-east-1:<ACCOUNT-ID>:table/DVSA-ORDERS-DB/index/*"
      ]
    }
  ]
}
